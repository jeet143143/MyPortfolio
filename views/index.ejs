<%- include('./partials/header.ejs') %>

<!-- 3D Canvas Background for Hero -->
<canvas id="webgl-canvas"></canvas>

<main class="main-content">
    
    <!-- HERO SECTION -->
    <section id="hero" class="hero-section text-center">
    <canvas id="webgl-canvas"></canvas>
        <h1 class="hero-title reveal-text">
            <span>JEET</span> 
            <span class="gradient-text">SENAPATI</span>
        </h1>
        <p class="hero-subtitle type-effect">Full Stack Developer | AI & ML Enthusiast</p>
        <div class="hero-cta d-flex justify-content-center" style="gap: 1.5rem; align-items: center;">
            <a href="#projects" class="btn-solid magnetic-element">VIEW_WORK</a>
            <a href="https://drive.google.com/file/d/1S3X6R9DwfukAnA6X0ulK6YtVEQrzok80/view?usp=sharing" target="_blank" class="btn-outline magnetic-element">VIEW_RESUME</a>
        </div>
        <div class="scroll-indicator">
            <div class="mouse"></div>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="section-padding content-section">
        <div class="container">
            <h2 class="section-title text-center scroll-fade mb-5"><span class="neon-number">01.</span> ABOUT_ME</h2>
            <div class="about-grid">
                <div class="about-image-container scroll-fade magnetic-element">
                    <div class="profile-glow"></div>
                    <img src="/profile.jpg" alt="Jeet Senapati" class="profile-img">
                    <div class="cyber-frame"></div>
                </div>
                <div class="about-text-container scroll-fade">
                    <div class="glass-card about-card" data-tilt data-tilt-max="3" data-tilt-speed="600" data-tilt-glare data-tilt-max-glare="0.2">
                        <h3 class="neon-text mb-3">INITIALIZING PROFILE...</h3>
                        <p class="stagger-text">A passionate B.Tech student specializing in Computer Science and Information technology. Skilled in programming, web development and foundational cybersecurity principles. I have a keen interest in AI and machine learning, and I have successfully implemented projects integrating AI-driven solutions with dynamic web development.</p>
                        <div class="edu-stamp mt-4">
                            <small class="gradient-text font-bold">B.Tech CS & IT - UEM Kolkata // CGPA 8.01</small>
                        </div>
                        <div class="mt-4 d-flex" style="gap: 1rem; align-items: center;">
                            <a href="#projects" class="btn-solid magnetic-element">VIEW_ARCHIVES</a>
                            <a href="https://drive.google.com/file/d/1S3X6R9DwfukAnA6X0ulK6YtVEQrzok80/view?usp=sharing" target="_blank" class="btn-resume magnetic-element">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                GET RESUME
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SKILLS SECTION -->
    <section id="skills" class="section-padding content-section">
        <div class="container">
            <h2 class="section-title text-center scroll-fade"><span class="neon-number">02.</span> TECH_STACK</h2>
            <div class="skills-grid">
                <!-- Skill items to be animated -->
                <div class="skill-card magnetic-element scroll-scale">
                    <h3>Frontend</h3>
                    <p>HTML5, CSS3, JS, React, Three.js, GSAP</p>
                </div>
                <div class="skill-card magnetic-element scroll-scale" style="transition-delay: 100ms">
                    <h3>Backend</h3>
                    <p>Node.js, Express, Java, Python, REST APIs</p>
                </div>
                <div class="skill-card magnetic-element scroll-scale" style="transition-delay: 200ms">
                    <h3>Database & Cloud</h3>
                    <p>MongoDB, Vercel, Railway</p>
                </div>
                <div class="skill-card magnetic-element scroll-scale" style="transition-delay: 300ms">
                    <h3>AI & ML</h3>
                    <p>OpenAI API, LLMs, Neural Networks</p>
                </div>
            </div>
        </div>
    </section>

    <!-- PROJECTS SECTION -->
    <section id="projects" class="section-padding content-section">
        <div class="container">
            <h2 class="section-title text-center scroll-fade"><span class="neon-number">03.</span> FEATURED_PROJECTS</h2>
        <div class="projects-wrapper"> <!-- changed this to grid later -->
                <% if(projects && projects.length > 0) { %>
                    <div class="projects-grid">
                        <% projects.forEach((proj, index) => { %>
                            <div class="project-glass-card scroll-fade magnetic-element" data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare data-tilt-max-glare="0.3">
                                <div class="project-image-wrapper">
                                    <% if(proj.imageUrl) { %>
                                        <img src="<%= proj.imageUrl %>" alt="<%= proj.title %>" class="project-thumbnail">
                                    <% } else { %>
                                        <div class="project-placeholder"></div>
                                    <% } %>
                                </div>
                                <div class="project-content">
                                    <h3 class="neon-text"><%= proj.title %></h3>
                                    <p><%= proj.description %></p>
                                    <div class="tech-tags">
                                        <% proj.techStack.forEach(t => { %>
                                            <span class="tag"><%= t %></span>
                                        <% }) %>
                                    </div>
                                    <a href="<%= proj.repoLink || '#' %>" target="_blank" class="btn-outline w-100 text-center" style="display:block; margin-top:2rem;">VIEW_SOURCE</a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="project-card scroll-fade no-projects">
                        <div class="project-content text-center w-100">
                            <h3><span class="neon-text">SYS.LOG:</span> NO RECENT FILES FOUND</h3>
                            <p>Projects are being assembled in the mainframe...</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- CONTACT SECTION -->
    <section id="contact" class="section-padding content-section">
        <div class="container text-center">
            <h2 class="section-title scroll-fade"><span class="neon-number">04.</span> INITIATE_CONTACT</h2>
            <div class="contact-form-container glass-card mx-auto scroll-fade" data-tilt data-tilt-max="2" data-tilt-speed="500" data-tilt-glare data-tilt-max-glare="0.1">
                <form id="contact-form">
                    <div class="input-group">
                        <input type="text" id="contact-name" placeholder="TERMINAL_ID (Name)" required>
                    </div>
                    <div class="input-group">
                        <input type="email" id="contact-email" placeholder="COM_LINK (Email)" required>
                    </div>
                    <div class="input-group">
                        <textarea id="contact-content" rows="4" placeholder="TRANSMISSION_DATA (Message)" required></textarea>
                    </div>
                    <button type="submit" class="btn-neon w-100 mt-4"><span>TRANSMIT_</span></button>
                    <p id="contact-status" class="mt-2"></p>
                </form>
            </div>
        </div>
    </section>

</main>

<%- include('./partials/footer.ejs') %>
